# ── Airdrop / wallet connection ─────────────────────────────────────
# WalletConnect Cloud project ID — required for mobile wallet
# connections (QR code + deep links) via RainbowKit. Free at
# https://cloud.reown.com (formerly cloud.walletconnect.com).
# Browser-extension wallets still work without it.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# NOTE: distribution is manual — applications are collected in
# airdrop-applications.json and listed at /admin/airdrop. You send the
# MRT yourself from the treasury wallet, so no private key is needed.

# ── App data (optional) ─────────────────────────────────────────────
# MongoDB connection for the dapp's collections (properties, pools,
# escrow, DAO votes…). If unset, data lives in app-data-*.json files
# seeded from lib/appSeed.ts — the app works either way.
MONGODB_URI=
# Optional database name (defaults to the one in the URI)
# MONGODB_DB=mortgage

# ── Admin (optional) ────────────────────────────────────────────────
# When set, /admin write actions require this key (x-admin-key header;
# the admin pages have an input for it). Unset = open, like /admin/emails.
ADMIN_KEY=
